{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "AKS with Node Auto Provisioning (NAP/Karpenter) in a NEW VNet. CNI Overlay + Cilium. Spot/ondemand Karpenter NodePools are applied separately via kubectl."
  },
  "parameters": {
    "clusterName": {
      "type": "string",
      "defaultValue": "aks-nap",
      "minLength": 1,
      "maxLength": 63,
      "metadata": { "description": "Must start with a letter or number." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Region MUST have your spot quota. Provide your own." }
    },
    "kubernetesVersion": { "type": "string", "defaultValue": "1.35.4" },
    "identityName": {
      "type": "string",
      "defaultValue": "[format('{0}-cp-identity', parameters('clusterName'))]"
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "aksvnet",
      "minLength": 2,
      "maxLength": 64,
      "metadata": { "description": "VNet name. Must start with a letter; letters/numbers/'.'/'-'/'_' only." }
    },
    "vnetAddressPrefix": { "type": "string", "defaultValue": "10.224.0.0/16" },
    "nodeSubnetName":    { "type": "string", "defaultValue": "nodes" },
    "nodeSubnetPrefix":  {
      "type": "string",
      "defaultValue": "10.224.0.0/24",
      "metadata": { "description": "Overlay mode: subnet only holds node IPs, not pods. /24 ~= 250 nodes." }
    },
    "systemNodeVmSize":  {
      "type": "string",
      "defaultValue": "Standard_D2s_v5",
      "metadata": { "description": "Zone-redundant-capable SKU in westus2. Note: D2s_v5 is single-zone (zone 2) in westus2 for some subscriptions, which breaks zone redundancy there." }
    },
    "systemNodeCount":   { "type": "int", "defaultValue": 2, "minValue": 1, "maxValue": 5 },
    "availabilityZones": {
      "type": "array",
      "defaultValue": [],
      "metadata": { "description": "Empty = non-zonal (deploys anywhere). Set [\"1\",\"2\",\"3\"] ONLY where the chosen SKU+subscription actually offers those zones (verify with: az vm list-skus -l <region> --size <sku> --query \"[0].locationInfo[0].zones\")." }
    },
    "podCidr":           { "type": "string", "defaultValue": "10.244.0.0/16" },
    "serviceCidr":       { "type": "string", "defaultValue": "10.0.0.0/16" },
    "dnsServiceIP":      { "type": "string", "defaultValue": "10.0.0.10" },
    "aadTenantId":       { "type": "string", "defaultValue": "[subscription().tenantId]" }
  },
  "variables": {
    "subnetId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('nodeSubnetName'))]",
    "networkContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4d97b98b-1d4f-4787-a291-c67834d212e7')]",
    "roleAssignmentName": "[guid(resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName')), parameters('identityName'), 'NetworkContributor')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": { "addressPrefixes": [ "[parameters('vnetAddressPrefix')]" ] },
        "subnets": [
          {
            "name": "[parameters('nodeSubnetName')]",
            "properties": { "addressPrefix": "[parameters('nodeSubnetPrefix')]" }
          }
        ]
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[parameters('identityName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[variables('roleAssignmentName')]",
      "scope": "[format('Microsoft.Network/virtualNetworks/{0}', parameters('vnetName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('networkContributorRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.ContainerService/managedClusters",
      "apiVersion": "2026-01-02-preview",
      "name": "[parameters('clusterName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName'))]",
        "[extensionResourceId(resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName')), 'Microsoft.Authorization/roleAssignments', variables('roleAssignmentName'))]"
      ],
      "sku": { "name": "Base", "tier": "Free" },
      "kind": "Base",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName'))]": {}
        }
      },
      "properties": {
        "kubernetesVersion": "[parameters('kubernetesVersion')]",
        "dnsPrefix": "[format('{0}-dns', parameters('clusterName'))]",
        "enableRBAC": true,
        "disableLocalAccounts": true,
        "agentPoolProfiles": [
          {
            "name": "agentpool",
            "mode": "System",
            "count": "[parameters('systemNodeCount')]",
            "vmSize": "[parameters('systemNodeVmSize')]",
            "osType": "Linux",
            "osSKU": "Ubuntu",
            "osDiskSizeGB": 128,
            "osDiskType": "Managed",
            "maxPods": 110,
            "type": "VirtualMachineScaleSets",
            "enableAutoScaling": false,
            "availabilityZones": "[if(empty(parameters('availabilityZones')), null(), parameters('availabilityZones'))]",
            "vnetSubnetID": "[variables('subnetId')]",
            "upgradeSettings": { "maxSurge": "10%", "maxUnavailable": "0" }
          }
        ],
        "networkProfile": {
          "networkPlugin": "azure",
          "networkPluginMode": "overlay",
          "networkPolicy": "cilium",
          "networkDataplane": "cilium",
          "loadBalancerSku": "Standard",
          "outboundType": "loadBalancer",
          "podCidr": "[parameters('podCidr')]",
          "serviceCidr": "[parameters('serviceCidr')]",
          "dnsServiceIP": "[parameters('dnsServiceIP')]",
          "ipFamilies": [ "IPv4" ]
        },
        "nodeProvisioningProfile": {
          "mode": "Auto",
          "defaultNodePools": "Auto"
        },
        "aadProfile": {
          "managed": true,
          "enableAzureRBAC": true,
          "tenantID": "[parameters('aadTenantId')]"
        },
        "oidcIssuerProfile": { "enabled": true },
        "securityProfile": {
          "workloadIdentity": { "enabled": true },
          "imageCleaner": { "enabled": true, "intervalHours": 168 }
        },
        "storageProfile": {
          "diskCSIDriver": { "enabled": true },
          "fileCSIDriver": { "enabled": true },
          "snapshotController": { "enabled": true }
        },
        "autoUpgradeProfile": {
          "upgradeChannel": "patch",
          "nodeOSUpgradeChannel": "NodeImage"
        },
        "bootstrapProfile": { "artifactSource": "Direct" }
      }
    },
    {
      "type": "Microsoft.ContainerService/managedClusters/maintenanceConfigurations",
      "apiVersion": "2026-01-02-preview",
      "name": "[format('{0}/aksManagedAutoUpgradeSchedule', parameters('clusterName'))]",
      "dependsOn": [ "[resourceId('Microsoft.ContainerService/managedClusters', parameters('clusterName'))]" ],
      "properties": {
        "maintenanceWindow": {
          "schedule": { "weekly": { "intervalWeeks": 1, "dayOfWeek": "Sunday" } },
          "durationHours": 8, "utcOffset": "+00:00", "startTime": "00:00"
        }
      }
    },
    {
      "type": "Microsoft.ContainerService/managedClusters/maintenanceConfigurations",
      "apiVersion": "2026-01-02-preview",
      "name": "[format('{0}/aksManagedNodeOSUpgradeSchedule', parameters('clusterName'))]",
      "dependsOn": [ "[resourceId('Microsoft.ContainerService/managedClusters', parameters('clusterName'))]" ],
      "properties": {
        "maintenanceWindow": {
          "schedule": { "weekly": { "intervalWeeks": 1, "dayOfWeek": "Sunday" } },
          "durationHours": 8, "utcOffset": "+00:00", "startTime": "00:00"
        }
      }
    }
  ],
  "outputs": {
    "clusterName":  { "type": "string", "value": "[parameters('clusterName')]" },
    "vnetName":     { "type": "string", "value": "[parameters('vnetName')]" },
    "nodeSubnetId": { "type": "string", "value": "[variables('subnetId')]" }
  }
}
